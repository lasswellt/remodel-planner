rules_version = '2';

// Owner-only access to per-user storage; writes must be images under 10MB.
// Mirrors the Firestore user-subtree scoping. Phase 10 (photos) verifies
// these rules against the dev project (second account denied, non-image
// rejected, >10MB rejected).
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
