rules_version = '2';

// Everything is scoped under users/{uid}. A document is readable/writable only
// by its authenticated owner, OR by a project member (editor role) whose
// membership doc exists at users/{ownerUid}/projects/{projectId}/members/{memberUid}.
//
// Project-wide dashboards use collection-group queries on tasks and items;
// those are authorized by the denormalized resource.data.uid.
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function ownsPayload(uid) {
      return request.resource.data.uid == uid;
    }

    function isEnum(field, allowed) {
      return field is string && field in allowed;
    }

    // Check membership via existence of the member doc (cheaper than get()).
    function isMember(ownerUid, projectId) {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(ownerUid)/projects/$(projectId)/members/$(request.auth.uid));
    }

    // A membership may only be created if it is backed by an existing, unexpired
    // invite for THIS project. Enforced server-side so revoked/expired invites —
    // and direct writes that skip the in-app accept flow — cannot grant access.
    function inviteValidFor(ownerUid, projectId, token) {
      let path = /databases/$(database)/documents/invites/$(token);
      return token is string && exists(path)
        && get(path).data.ownerUid == ownerUid
        && get(path).data.projectId == projectId
        && get(path).data.expiresAt > request.time;
    }

    // ---- per-entity field validation ----
    function validRoom() {
      let d = request.resource.data;
      return d.name is string
        && isEnum(d.type, ['kitchen','bathroom','bedroom','living-room','dining-room','home-office','laundry-utility','mudroom-entry','hallway-stairs','garage','exterior'])
        && isEnum(d.status, ['planned','in-progress','done']);
    }
    function validTask() {
      let d = request.resource.data;
      return d.label is string
        && isEnum(d.phase, ['demo','rough-in','insulation','drywall','paint','flooring','trim','fixtures','punch-list'])
        && isEnum(d.status, ['todo','in-progress','blocked','done']);
    }
    function validBudgetLine() {
      let d = request.resource.data;
      return d.label is string
        && isEnum(d.category, ['materials','labor','permits','fixtures','other'])
        && d.estimateCents is int && d.estimateCents >= 0;
    }
    function validPermit() {
      let d = request.resource.data;
      return d.scope is string
        && isEnum(d.status, ['needed','applied','issued','closed']);
    }
    function validPhoto() {
      let d = request.resource.data;
      return d.storagePath is string
        && isEnum(d.stage, ['before','during','after']);
    }
    function validChecklist() {
      let d = request.resource.data;
      return d.label is string && d.done is bool;
    }
    function validInspiration() {
      let d = request.resource.data;
      return d.title is string && d.url is string;
    }
    function validPaint() {
      let d = request.resource.data;
      return d.name is string;
    }
    // Unified Shopping & Selections item. Lenient: only the always-present
    // fields are required (label + a valid lifecycle status); everything else —
    // category, rank, lead time, budget link — is optional per phase.
    function validItem() {
      let d = request.resource.data;
      return d.label is string
        && isEnum(d.status, ['idea','to-buy','purchased','delivered','installed']);
    }

    // ---- invite tokens (top-level) ----
    // Any signed-in user can read an invite to accept it.
    // Only the owning user can create or revoke invites for their projects.
    match /invites/{token} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.ownerUid == request.auth.uid;
    }

    // ---- collection-group reads for project-wide dashboards + rollups ----
    // Owner reads by their own denormalized uid; a project member reads via
    // isMember(ownerUid, projectId) — every OwnerScoped doc carries both uid
    // and projectId, so the rollup query (filtered by the OWNER uid) resolves
    // for members too. Without the isMember branch a member's rings read empty.
    match /{path=**}/tasks/{taskId} {
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid || isMember(resource.data.uid, resource.data.projectId));
    }
    match /{path=**}/checklist/{itemId} {
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid || isMember(resource.data.uid, resource.data.projectId));
    }
    match /{path=**}/budgetLines/{lineId} {
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid || isMember(resource.data.uid, resource.data.projectId));
    }
    match /{path=**}/photos/{photoId} {
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid || isMember(resource.data.uid, resource.data.projectId));
    }
    match /{path=**}/items/{itemId} {
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid || isMember(resource.data.uid, resource.data.projectId));
    }

    // ---- the owned subtree ----
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      // Shared-project pointers written when the user accepts an invite.
      match /sharedProjects/{refId} {
        allow read, write: if isOwner(uid);
      }

      match /projects/{projectId} {
        allow read: if isOwner(uid) || isMember(uid, projectId);
        allow create: if isOwner(uid)
          && request.resource.data.uid == uid
          && request.resource.data.name is string
          && request.resource.data.totalBudgetCents is int;
        allow update: if isOwner(uid)
          && request.resource.data.uid == uid
          && request.resource.data.name is string
          && request.resource.data.totalBudgetCents is int;
        allow delete: if isOwner(uid);

        // Members subcollection. A user creates their own membership doc when
        // accepting an invite — but only with a valid, unexpired invite token for
        // this project (see inviteValidFor). Membership is immutable (no update);
        // only the owner or the member themselves can delete it.
        match /members/{memberUid} {
          allow read: if isOwner(uid) || request.auth.uid == memberUid;
          allow create: if request.auth != null
            && request.auth.uid == memberUid
            && request.resource.data.uid == memberUid
            && request.resource.data.role == 'editor'
            && request.resource.data.inviteToken is string
            && inviteValidFor(uid, projectId, request.resource.data.inviteToken);
          allow delete: if isOwner(uid) || (request.auth != null && request.auth.uid == memberUid);
        }

        match /rooms/{roomId} {
          allow read: if isOwner(uid) || isMember(uid, projectId);
          allow create, update: if (isOwner(uid) || isMember(uid, projectId)) && ownsPayload(uid) && validRoom();
          allow delete: if isOwner(uid) || isMember(uid, projectId);

          match /checklist/{itemId} {
            allow read: if isOwner(uid) || isMember(uid, projectId);
            allow create, update: if (isOwner(uid) || isMember(uid, projectId)) && ownsPayload(uid) && validChecklist();
            allow delete: if isOwner(uid) || isMember(uid, projectId);
          }
          match /budgetLines/{lineId} {
            allow read: if isOwner(uid) || isMember(uid, projectId);
            allow create, update: if (isOwner(uid) || isMember(uid, projectId)) && ownsPayload(uid) && validBudgetLine();
            allow delete: if isOwner(uid) || isMember(uid, projectId);
          }
          match /tasks/{taskId} {
            allow read: if isOwner(uid) || isMember(uid, projectId);
            allow create, update: if (isOwner(uid) || isMember(uid, projectId)) && ownsPayload(uid) && validTask();
            allow delete: if isOwner(uid) || isMember(uid, projectId);
          }
          match /photos/{photoId} {
            allow read: if isOwner(uid) || isMember(uid, projectId);
            allow create, update: if (isOwner(uid) || isMember(uid, projectId)) && ownsPayload(uid) && validPhoto();
            allow delete: if isOwner(uid) || isMember(uid, projectId);
          }
          match /paints/{paintId} {
            allow read: if isOwner(uid) || isMember(uid, projectId);
            allow create, update: if (isOwner(uid) || isMember(uid, projectId)) && ownsPayload(uid) && validPaint();
            allow delete: if isOwner(uid) || isMember(uid, projectId);
          }
          // Unified Shopping & Selections collection (merged from the former
          // selections + purchases collections).
          match /items/{itemId} {
            allow read: if isOwner(uid) || isMember(uid, projectId);
            allow create, update: if (isOwner(uid) || isMember(uid, projectId)) && ownsPayload(uid) && validItem();
            allow delete: if isOwner(uid) || isMember(uid, projectId);
          }
        }

        match /permits/{permitId} {
          allow read: if isOwner(uid) || isMember(uid, projectId);
          allow create, update: if (isOwner(uid) || isMember(uid, projectId)) && ownsPayload(uid) && validPermit();
          allow delete: if isOwner(uid) || isMember(uid, projectId);
        }
        match /inspiration/{itemId} {
          allow read: if isOwner(uid) || isMember(uid, projectId);
          allow create, update: if (isOwner(uid) || isMember(uid, projectId)) && ownsPayload(uid) && validInspiration();
          allow delete: if isOwner(uid) || isMember(uid, projectId);
        }
      }
    }
  }
}
