# Copy to .env.development (dev project web config) and .env.production (prod
# project web config). `nuxt dev` always loads .env.development; `nuxt generate`
# in production mode loads .env.production. All values come from
# `firebase apps:sdkconfig WEB <appId> --project <dev|prod>`.
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=

# App Check — reCAPTCHA Enterprise site key (public). Required for prod;
# optional in dev (App Check stays off until this is set).
NUXT_PUBLIC_RECAPTCHA_ENTERPRISE_KEY=

# Dev-only App Check debug token (never commit a real value).
FIREBASE_APPCHECK_DEBUG_TOKEN=
